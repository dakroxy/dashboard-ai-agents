# Template fuer die Produktiv-Env-Variablen auf Elestio.
#
# In Elestio werden diese Werte NICHT als Datei, sondern im
# Service-Dashboard unter "Environment Variables" gesetzt.
# Diese Datei dient nur als Checkliste / Referenz.
#
# WICHTIG: KEINE echten Secrets hier eintragen — die Datei ist
# im Git-Repo. Echte Werte ausschliesslich in Elestio.

# --- App ---
APP_ENV=production
# Die oeffentliche URL, unter der das Dashboard erreichbar ist.
# Wird fuer OAuth-Redirects + https_only-Cookies verwendet.
BASE_URL=https://dashboard.dbshome.de

# 32-Byte Zufalls-Hex fuer Session-Cookies.
# Neu generieren mit: python -c "import secrets; print(secrets.token_hex(32))"
# NICHT den Dev-Wert wiederverwenden.
SECRET_KEY=__GENERATE_FRESH_64_HEX_CHARS__

# --- Postgres ---
# POSTGRES_HOST bleibt "db" — Servicename im Compose-Netzwerk.
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=dashboard
# Langes Zufallspasswort fuer Prod. Neu generieren mit:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_PASSWORD=__GENERATE_FRESH_STRONG_PASSWORD__
POSTGRES_DB=dashboard

# --- Google Workspace OAuth ---
# Gleiche OAuth-App wie Dev; zusaetzlich muss in der Google Cloud Console
# die Redirect-URI https://dashboard.dbshome.de/auth/google/callback
# eingetragen sein.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_HOSTED_DOMAIN=dbshome.de

# --- Anthropic / Claude ---
ANTHROPIC_API_KEY=

# --- Impower ---
IMPOWER_BASE_URL=https://api.app.impower.de
IMPOWER_BEARER_TOKEN=

# --- Bootstrap ---
# Komma-separiert. Diese E-Mails werden beim ersten Login automatisch Admins.
INITIAL_ADMIN_EMAILS=kroll@dbshome.de
