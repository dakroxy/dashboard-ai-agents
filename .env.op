# 1Password-Template fuer lokale Dev-Umgebung.
# Aufloesen mit:  scripts/env.sh     (oder manuell: op inject -i .env.op -o .env)
# Voraussetzung:  OP_SERVICE_ACCOUNT_TOKEN gesetzt (Keychain-Entry op-service-account-ki)
#
# Diese Datei darf committet werden — sie enthaelt keine Secrets,
# nur 1Password-Referenzen. Die aufgeloeste .env bleibt ignored.

APP_ENV=development
BASE_URL=http://localhost:8000

# Dev-Only (nicht schutzwuerdig): in Prod via Elestio-Env-Variablen setzen.
SECRET_KEY=dev-secret-7f3a2c9e8b1d4a6f0e5c2b8d9a7e3f1c4b6d8a0f2e5c7b9d1a3f5e7c9b1d3a5f
POSTGRES_USER=dashboard
POSTGRES_PASSWORD=dev-postgres-change-in-prod
POSTGRES_DB=dashboard
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Google Workspace OAuth (Internal App, hd-Beschraenkung auf dbshome.de)
GOOGLE_CLIENT_ID=op://KI/Google OAuth - HV Dashboard AI Agents/username
GOOGLE_CLIENT_SECRET=op://KI/Google OAuth - HV Dashboard AI Agents/credential
GOOGLE_HOSTED_DOMAIN=dbshome.de

# Anthropic / Claude
ANTHROPIC_API_KEY=op://KI/Claude API Key - Lastschrift/credential

# Impower-API (kommt in M2)
IMPOWER_BASE_URL=https://api.app.impower.de
IMPOWER_BEARER_TOKEN=op://KI/Impower API Token PowerAutomate/credential

# Beim ersten Login werden diese E-Mails automatisch zu Admins promotet.
INITIAL_ADMIN_EMAILS=kroll@dbshome.de
